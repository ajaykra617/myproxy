PORT=3000
REDIS_URL=redis://redis:6379
POSTGRES_URL=postgres://postgres:postgres@db:5432/myproxy

# Proxy Relay
# ─────────────────────────────────────────────────────────────────────────────
# RELAY_HOST  – public hostname or IP clients will use to reach the relay.
#               On the gyd.ai server this should be "gyd.ai" (the relay port
#               is exposed directly; it cannot go through Caddy).
# RELAY_PORT  – relay port exposed on the host (default 8080).
#               Make sure this port is open in the server firewall.
#
# The API itself (port 3100 → 3000) CAN sit behind Caddy:
#   Add to /etc/caddy/Caddyfile:
#     myproxy.gyd.ai {
#         reverse_proxy localhost:3100
#     }
#
# Leave RELAY_HOST blank for local/dev mode (proxy_string returned directly).
# RELAY_HOST=gyd.ai
# RELAY_PORT=8080

# Providers

# Bright Data Residential gateway
# The password must come from the Bright Data dashboard; do not commit it.
# Host/customer/zone default in code to the current residential_proxy1 account,
# so production only needs BRIGHTDATA_PASSWORD as a secret unless those change.
BRIGHTDATA_ENABLED=true
BRIGHTDATA_HOST=brd.superproxy.io
BRIGHTDATA_PORT=33335
BRIGHTDATA_CUSTOMER_ID=hl_8a6ef076
BRIGHTDATA_ZONE=residential_proxy1
BRIGHTDATA_PASSWORD=
BRIGHTDATA_PROTOCOL=http
# Optional default geo if callers omit ?country=. Requests can also pass
# country, state, asn, or ip to append Bright Data username options.
# BRIGHTDATA_COUNTRY=US


PROXY_MANAGER_API_KEY=replace_with_strong_shared_key
PROXY_MANAGER_API_KEY_HEADER=x-api-key
